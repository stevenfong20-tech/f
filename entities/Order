{
  "name": "Order",
  "type": "object",
  "properties": {
    "branch_id": {
      "type": "string",
      "description": "ID of the branch that placed the order"
    },
    "branch_name": {
      "type": "string",
      "description": "Name of the branch"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "preparing",
        "ready_for_pickup",
        "completed",
        "cancelled"
      ],
      "default": "pending"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name_zh": {
            "type": "string"
          },
          "product_name_en": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "unit_zh": {
            "type": "string"
          },
          "unit_en": {
            "type": "string"
          },
          "subtotal": {
            "type": "number"
          }
        }
      }
    },
    "total_amount": {
      "type": "number"
    },
    "notes": {
      "type": "string"
    },
    "special_instructions": {
      "type": "string",
      "description": "Special instructions like extra spicy, no garlic, etc."
    },
    "order_date": {
      "type": "string",
      "format": "date"
    },
    "status_history": {
      "type": "array",
      "description": "Timeline of status changes",
      "items": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "branch_id",
    "branch_name",
    "total_amount"
  ]
}
